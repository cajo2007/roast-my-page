# Database — PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/roast_my_page"

# App — set to your production domain in production
NEXT_PUBLIC_APP_URL="https://roastyourpage.com"

# OpenAI — required for roast generation
OPENAI_API_KEY=""

# Clerk — authentication (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# Stripe — credit pack checkout (https://dashboard.stripe.com)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Stripe price IDs — create these in the Stripe dashboard as one-time prices
# Starter: 3 credits, £3
STRIPE_PRICE_ID_3_CREDITS=""
# Value: 10 credits, £7
STRIPE_PRICE_ID_10_CREDITS=""
